# RepoWeaver configuration. Copy to .env and adjust, or export these directly.
# All values are optional; defaults let the app run with zero setup.

# HTTP port for the local web server.
PORT=8080

# SQLite database file path.
DB_PATH=./repoweaver.db

# Open the default browser automatically on startup (true/false).
OPEN_BROWSER=false

# GitHub personal access token. Optional, but strongly recommended:
# unauthenticated requests are heavily rate-limited (and may be blocked).
GITHUB_TOKEN=

# LLM provider: mock (default, keyless) | claude | openai | gemini
LLM_PROVIDER=mock

# API key for the selected provider (not needed for mock).
LLM_API_KEY=

# Optional model override. Defaults per provider:
#   claude -> claude-sonnet-4-6
#   openai -> gpt-4o
#   gemini -> gemini-1.5-pro
LLM_MODEL=
