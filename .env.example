# RepoWeaver configuration. Copy to .env and adjust, or export these directly.
# All values are optional; defaults let the app run with zero setup.

# HTTP port for the local web server.
PORT=8080

# SQLite database file path.
DB_PATH=./repoweaver.db

# Open the default browser automatically on startup (true/false).
OPEN_BROWSER=false

# GitHub personal access token. Optional, but strongly recommended:
# unauthenticated requests are heavily rate-limited (and may be blocked).
GITHUB_TOKEN=

# LLM provider: mock (default, keyless) | claude | openai | gemini
LLM_PROVIDER=mock

# API key for the selected provider (not needed for mock).
LLM_API_KEY=

# Optional model override. Defaults per provider:
#   claude -> claude-sonnet-4-6
#   openai -> gpt-4o
#   gemini -> gemini-1.5-pro
LLM_MODEL=

# Analytics provider (Phase 6): none (default) | ga4 | demo
#   demo -> deterministic sample metrics for exploring the dashboard
#   ga4  -> live Google Analytics 4 (requires the settings below)
ANALYTICS_PROVIDER=none

# GA4 numeric property ID (e.g. 123456789).
GA4_PROPERTY_ID=

# GA4 authentication — choose ONE of the two approaches below.
#
# (A) Browser OAuth (recommended for a single user): set an OAuth 2.0 client
#     (Web application) from Google Cloud, then click "Connect Google Analytics"
#     on the /analytics page. Add the redirect URI
#     http://localhost:8080/analytics/oauth/callback to the client.
GA4_OAUTH_CLIENT_ID=
GA4_OAUTH_CLIENT_SECRET=
#
# (B) Service account with the Analytics Data API enabled (no browser step).
#     Provide ONE of:
#       GA4_CREDENTIALS_FILE -> path to the service-account JSON key file
#       GA4_CREDENTIALS_JSON -> the service-account JSON inline
GA4_CREDENTIALS_FILE=
GA4_CREDENTIALS_JSON=
